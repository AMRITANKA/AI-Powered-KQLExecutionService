# Azure Application Insights Configuration
APPINSIGHTS_CONNECTION_STRING="Your-App-Insights-Connection-String"

# LLM Configuration - Choose your provider
# Option 1: OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"

# Option 2: Anthropic
# ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# Option 3: Custom (e.g., opencode.ai, MiniMax)
# LLM_API_KEY="your-opencode-api-key"

# API Security
API_KEY="your-secure-api-key-for-clients"

# Server Configuration (optional, defaults in config.yaml)
# PORT=3000
# HOST="0.0.0.0"

# Logging (optional)
# LOG_LEVEL="info"